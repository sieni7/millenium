{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MILLENIUM Config Schema",
  "type": "object",
  "required": ["company", "contact", "design", "hero", "activities"],
  "properties": {
    "company": {
      "type": "object",
      "required": ["name", "rccm", "bp", "address", "manager"],
      "properties": {
        "name": { "type": "string" },
        "rccm": { "type": "string" },
        "bp": { "type": "string" },
        "address": { "type": "string" },
        "manager": { "type": "string" }
      }
    },
    "contact": {
      "type": "object",
      "required": ["phone", "email"],
      "properties": {
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "social": {
          "type": "object",
          "properties": {
            "facebook": { "type": "string" },
            "linkedin": { "type": "string" },
            "twitter": { "type": "string" }
          }
        }
      }
    },
    "design": {
      "type": "object",
      "properties": {
        "colors": {
          "type": "object",
          "properties": {
            "primary": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
            "secondary": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
            "accent": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" }
          }
        }
      }
    },
    "hero": {
      "type": "object",
      "properties": {
        "slides": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["title", "text", "image", "cta"],
            "properties": {
              "title": { "type": "string" },
              "text": { "type": "string" },
              "image": { "type": "string" },
              "cta": { "type": "string" },
              "link": { "type": "string" }
            }
          }
        }
      }
    },
    "activities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "icon", "description"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "icon": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    }
  }
}
